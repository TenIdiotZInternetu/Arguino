<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gui.ViewModels"
             xmlns:cmgraph="clr-namespace:ComponentManagement.Graph;assembly=ComponentManagement"
             xmlns:tcontrol="clr-namespace:Gui.Views.TemplatedControls"
             x:Class="Gui.Views.UserControls.CircuitCanvas"
             x:DataType="vm:CircuitCanvas">

    <UserControl.Styles>
        <Style Selector="Panel">
            <Setter Property="Background" Value="{DynamicResource CanvasBackground}"/>
        </Style>
    </UserControl.Styles>

    <Panel ClipToBounds="False">
        <ZoomBorder Stretch="Fill" ClipToBounds="True" EnableDoubleClickZoom="False">

            <ItemsControl ItemsSource="{Binding Components}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas ClipToBounds="False"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
    
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="cmgraph:Component" >
                        <tcontrol:ComponentControl Component="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
        </ZoomBorder>
    </Panel>
</UserControl>
