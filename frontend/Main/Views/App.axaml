<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:usercontrols="using:Gui.Views.UserControls"
             x:Class="Gui.Views.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Gui/Views/Styles/General.axaml"/>
        <StyleInclude Source="avares://Gui/Views/Styles/ComponentStyle1.axaml"/>
    </Application.Styles>
</Application>